{
  "name": "web",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "typecheck": "nuxt typecheck",
    "test": "node -e \"require('fs').rmSync('.output',{ recursive: true, force: true })\" && npm run lint && npm run build",
    "test:e2e": "playwright test",
    "test:hero:capture": "node scripts/hero-capture.mjs",
    "test:visual": "node scripts/visual-test.mjs",
    "perf:measure": "node scripts/perf-metrics.mjs",
    "perf:gate": "node scripts/perf-metrics.mjs --enforce",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@img/sharp-win32-x64": "0.33.5",
    "@nuxt/image": "^1.8.1",
    "@phosphor-icons/vue": "^2.1.7",
    "@types/leaflet": "^1.9.21",
    "chart.js": "^4.5.1",
    "firebase": "^12.6.0",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^5.22.0",
    "nuxt": "3.12.4",
    "sharp": "^0.33.5",
    "vue": "^3.5.0",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.6.1",
    "@nuxt/eslint-config": "^1.12.1",
    "@nuxt/kit": "3.12.4",
    "@playwright/test": "^1.49.1",
    "autoprefixer": "10.4.20",
    "eslint": "^9.17.0",
    "eslint-webpack-plugin": "^4.2.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "^5.6.3",
    "vite-plugin-eslint2": "^5.0.3"
  }
}
