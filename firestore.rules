rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Baseline seguro: negar tudo para clients por padrão.
    // Admin SDK (Cloud Functions) não é afetado por estas regras.
    allow read: if request.auth != null && (request.auth.token.platformAdmin == true || request.auth.token.partner == true);
    
    // Regras específicas para Parceiros
    match /tenants/{tenantId}/config/features/promotions/{docId} {
      allow read, write: if request.auth != null && request.auth.token.partner == true && request.auth.token.tenantId == tenantId;
    }

    match /preCadastros/{docId} {
      allow read: if request.auth != null && (request.auth.token.partner == true || request.auth.uid == docId);
    }
  }
}
