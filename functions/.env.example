# Firebase Project
GCP_PROJECT=your-project-id
FIREBASE_CONFIG={"projectId":"your-project-id","storageBucket":"your-project.firebasestorage.app"}

# Internal Secrets (Parsed as JSON in secrets.ts)
# This should match the PainelConfig interface
PAINEL_CONFIG={ "whatsapp": { "accessToken": "...", "appSecret": "...", "verifyToken": "..." }, "google": { "vertexAI": { "projectId": "...", "location": "...", "ragCorpusId": "..." } }, "inter": { "clientId": "...", "clientSecret": "...", "certB64": "...", "keyB64": "...", "pixKey": "...", "webhookSecret": "..." }, "admin": { "apiKey": "...", "roboToken": "...", "billingKey": "...", "internalReplaySecret": "..." }, "dev": { "token": "...", "tokenCurrent": "...", "tokenPrevious": "..." } }

# Supported Regions
SUPPORTED_DDDS=81,85

# Thresholds and Timeouts
ORDER_AWAIT_DEPOSITO_MS=180000
DEV_SESSION_TTL_MS=1800000
